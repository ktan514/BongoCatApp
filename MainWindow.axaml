<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450" x:Class="BongoCatAPP.MainWindow" Title="BongoCat" TransparencyLevelHint="Transparent" Background="Transparent" SystemDecorations="None" Topmost="True" Width="180" Height="200" ShowInTaskbar="False" PointerReleased="OnPointerReleased">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Name="CounterText" Text="\ 0 /" FontSize="20" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center">
            <TextBlock.Effect>
                <DropShadowEffect Color="White" BlurRadius="5" OffsetX="0" OffsetY="0" Opacity="1" />
            </TextBlock.Effect>
        </TextBlock>
        <Image Name="CatImage" Source="" Width="150" PointerPressed="OnPointerPressed" PointerMoved="OnPointerMoved">
            <Image.ContextMenu>
                <ContextMenu Opened="OnCharacterMenuOpened">
                    <MenuItem x:Name="CharacterMenuRoot" Header="キャラクター" />
                    <Separator />
                    <MenuItem Header="終了する" Click="OnCloseClick" />
                </ContextMenu>
            </Image.ContextMenu>
        </Image>
    </StackPanel>
</Window>
